# Copy this to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Required
ANTHROPIC_API_KEY=sk-ant-...

# Slack — create a Slack App at api.slack.com/apps
# Required OAuth scopes: channels:history, channels:read, groups:history, groups:read
# Add the bot to each private channel with /invite @cx-briefing-bot
SLACK_BOT_TOKEN=xoxb-...

# Front — create an API token at app.frontapp.com/settings/tools/api
# Required permissions: Conversations:Read, Tags:Read, Inboxes:Read, Contacts:Read
FRONT_API_KEY=...

# Sentry — optional, set to enable error section
# Create token at sentry.io/settings/account/api/auth-tokens/
# Required scopes: org:read, project:read, event:read
SENTRY_AUTH_TOKEN=
SENTRY_ORG=stackblitz

# Optional: override lookback window (default: 16)
# LOOKBACK_HOURS=16

# Optional: Query + Front link base (shown as header buttons; tickets open in Front)
QUERY_NEW_URL=https://query.new/
QUERY_DASHBOARD_URL=https://query-new.utility.stackblitz.dev/dashboard/ba70a056-06d3-4a46-8340-6d18ac188683?chat=collapsed
QUERY_TICKET_ANALYZER_URL=https://query-new.utility.stackblitz.dev/workflows/7ccc7ec0-0de6-4ab2-a5e7-c9c178d29f43/798873df-143f-4632-ac45-ee417a68a47a
# FRONT_APP_BASE_URL=https://app.frontapp.com
