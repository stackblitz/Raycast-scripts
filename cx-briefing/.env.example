# Copy this to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Required
ANTHROPIC_API_KEY=sk-ant-...

# Slack — create a Slack App at api.slack.com/apps
# Required OAuth scopes: channels:history, channels:read, groups:history, groups:read
# Add the bot to each private channel with /invite @cx-briefing-bot
SLACK_BOT_TOKEN=xoxb-...

# Front — create an API token at app.frontapp.com/settings/tools/api
# Required permissions: Conversations:Read, Tags:Read, Inboxes:Read, Contacts:Read
# For Raycast `front-add-note.sh` (contact notes) also enable: Contacts:Write, Teammates:Read
FRONT_API_KEY=...

# Optional overrides for `author_id` on contact notes posted by
# front-add-note.sh / bolt-admin's "Log to Front" flow. By default the script
# auto-detects: macOS full name (`id -F`) → first word → firstname@stackblitz.com
# → /teammates lookup. If your Front email doesn't match that pattern, set
# FRONT_AUTHOR_EMAIL or FRONT_AUTHOR_ID below. Front rejects api/bot teammates
# here, so the value must be a real human teammate.
# FRONT_AUTHOR_EMAIL=you@stackblitz.com
# FRONT_AUTHOR_ID=tea_xxxxx

# Sentry — optional, set to enable error section
# Create token at sentry.io/settings/account/api/auth-tokens/
# Required scopes: org:read, project:read, event:read
SENTRY_AUTH_TOKEN=
SENTRY_ORG=stackblitz

# Linear — optional CX bug radar (GraphQL read API key at linear.app/settings/api)
# LINEAR_API_KEY=lin_api_...
# LINEAR_TEAM_IDS=uuid-one,uuid-two
# Optional: comma-separated label names to narrow (e.g. Bug + CX-tagged work)
# LINEAR_LABEL_NAMES=Bug,CX
# Optional: only issues filed by this user (CX bot / triage account email)
# LINEAR_CREATOR_EMAIL=cx@company.com
# “New” column uses calendar days, not LOOKBACK_HOURS (default 7)
# LINEAR_NEW_BUGS_DAYS=7
# LINEAR_MAX_ISSUES_FETCH=200

# Optional: override lookback window (default: 16)
# LOOKBACK_HOURS=16

# Optional: Query + Front link base (shown as header buttons; tickets open in Front)
QUERY_NEW_URL=https://query.new/
QUERY_DASHBOARD_URL=https://query-new.utility.stackblitz.dev/dashboard/ba70a056-06d3-4a46-8340-6d18ac188683?chat=collapsed
QUERY_TICKET_ANALYZER_URL=https://query-new.utility.stackblitz.dev/workflows/7ccc7ec0-0de6-4ab2-a5e7-c9c178d29f43/798873df-143f-4632-ac45-ee417a68a47a
# FRONT_APP_BASE_URL=https://app.frontapp.com
# Optional: max list requests when counting open tickets (100 per page). Default 30 ≈ 3000 tickets; raise if you need a full exact count on huge queues.
# FRONT_BRIEFING_MAX_PAGES=30
# Optional: conversation custom field keys so the briefing can read MRR + seats (add custom_fields:read on the token if needed)
# FRONT_MRR_FIELD_KEYS=mrr,subscription_mrr
# FRONT_SEATS_FIELD_KEYS=seats,team_members
